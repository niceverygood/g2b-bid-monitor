{
  "name": "g2b-attachment-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted worker: downloads g2b attachments (Playwright) and re-parses HWP 5.x via hwp5txt",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "playwright": "^1.47.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0"
  }
}
